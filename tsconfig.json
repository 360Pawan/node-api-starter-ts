{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "pretty": true,
    "target": "es6",
    "outDir": "./dist",
    "baseUrl": "./lib",
    "paths": {
      "@/*": ["*"]
    },
    "esModuleInterop": true
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules"]
}
