{
  "name": "employee-management",
  "version": "1.0.0",
  "description": "",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "nodemon -w lib -e ts --exec \"ts-node -r tsconfig-paths/register lib/server.ts\"",
    "prebuild:copy:temp": "copyfiles -u 1 lib/**/* temp",
    "prebuild": "npm run prebuild:copy:temp && tscpaths -p ./tsconfig.temp.json -s ./temp -o ./temp",
    "build": "tsc -p tsconfig.temp.json",
    "start": "npm run build && node dist/server.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.0",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "mongoose": "^7.3.4",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "tsc": "^2.0.4",
    "tsconfig-paths": "^4.2.0",
    "tscpaths": "^0.0.9"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "copyfiles": "^2.4.1"
  },
  "engines": {
    "node": ">=18.18.0 <19.0.0"
  }
}
